FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Embutir arquivos estáticos via base64 (independente de COPY)
RUN mkdir -p /app/static
RUN echo '' | base64 -d > /app/static/index.html
RUN echo '' | base64 -d > /app/static/app.js

COPY . .

RUN mkdir -p /app/data

EXPOSE 8000

CMD ["python", "main.py"]
