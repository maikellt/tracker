FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Embutir main.py via base64 (independente de rede/proxy)
# chunks de 10000 chars concatenados em /tmp/main.b64
RUN printf '' > /tmp/main.b64 \
    && printf '' >> /tmp/main.b64 \
    && printf '' >> /tmp/main.b64 \
    && printf '' >> /tmp/main.b64 \
    && printf '' >> /tmp/main.b64 \
    && printf '' >> /tmp/main.b64 \
    && base64 -d /tmp/main.b64 > /app/main.py \
    && echo "main.py: $(wc -l < /app/main.py) linhas" \
    && rm /tmp/main.b64

# Copiar requirements e demais arquivos Python do contexto local
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copiar scraper, database e agendador do contexto local
COPY scraper.py database.py agendador.py ./

RUN mkdir -p /app/data

EXPOSE 8000

CMD ["python", "main.py"]
